@charset "utf-8";

.cookies-top.cookies-bar-wrapper { display: none; width: 530px; z-index: 99=
990; background-color: rgb(255, 255, 255); border-radius: 4px; position: fi=
xed; bottom: 50px; right: 50px; box-shadow: rgba(0, 0, 0, 0.11) 0px 11px 47=
px 3px; }

div.cookies-list span.close { font-size: 0px; position: absolute; right: 14=
px; top: 5px; width: 40px; height: 40px; }

div.cookies-list span.close::after { width: 40px; height: 40px; display: bl=
ock; content: "+"; line-height: 30px; text-align: center; font-size: 40px; =
font-weight: normal; font-family: Arial, "Helvetica Neue", Helvetica, sans-=
serif; transform: rotate(45deg); }

.cookies-top .cookies-bar { padding: 30px 35px 0px; font-size: 16px; line-h=
eight: 24px; z-index: 99999; }

.cookies-bar-wrapper h2 { margin: 0px; padding: 0px 0px 20px; font-size: 20=
px; line-height: 25px; color: rgb(0, 134, 136); }

.cookies-bar-wrapper p { font-size: 16px; line-height: 24px; }

.cookies-bar-wrapper * { color: rgb(65, 65, 65); }

.cookies-bar-wrapper .bottom-buttons { padding-bottom: 20px; display: flex;=
 align-items: center; text-align: center; }

.cookies-bar-wrapper .btn { max-width: 45%; }

.bottom-buttons .btn.btn-primary { }

.bottom-buttons a.more.btn { color: rgb(0, 49, 65); float: right; backgroun=
d: none; border: 0px; padding: 0px; transition: linear; }

.bottom-buttons .btn-akcept-nutne { color: rgb(255, 255, 255); margin-left:=
 15px; }

div.cookies-list .btn.btn-primary { min-width: 120px; max-width: 150px; pos=
ition: absolute; left: 20px; bottom: 33px; }

.bottom-buttons a.more.btn:focus, .bottom-buttons a.more.btn:active { box-s=
hadow: 0px 0px 0px inset; }

.menu.resp-tabs-list { padding: 26px 0px 0px; margin: 0px 10px 20px; list-s=
tyle-type: none; font-size: 0px; border-bottom: 2px solid rgb(196, 196, 196=
); position: relative; height: 70px; max-height: 70px; overflow: visible; }

.menu.resp-tabs-list li { display: inline-block; height: 42px; line-height:=
 42px; background: none; margin: 0px 8px; padding: 0px 13px; border-width: =
1px 1px 2px; border-style: solid solid none; border-color: transparent tran=
sparent currentcolor; border-image: initial; position: relative; top: 2px; =
border-radius: 4px 4px 0px 0px; }

.menu.resp-tabs-list li.resp-tab-active { border-width: 1px 1px 2px; border=
-style: solid; border-color: rgb(196, 196, 196) rgb(196, 196, 196) rgb(255,=
 255, 255); border-image: initial; }

.menu.resp-tabs-list li a { text-decoration: none; font-size: 20px; font-we=
ight: 400; color: rgb(0, 0, 0); }

.menu.resp-tabs-list li:hover a, .menu.resp-tabs-list li.resp-tab-active a =
{ color: rgb(0, 159, 223); }

div.cookies-list { display: none; top: 50%; left: 50%; width: 960px; max-wi=
dth: 95%; max-height: 95vh; transform: translateX(-50%) translateY(-50%); b=
ackground: rgb(255, 255, 255); border-radius: 4px; position: fixed; box-sha=
dow: rgba(0, 0, 0, 0.11) 0px 11px 47px 3px; z-index: 99995; }

.cookies-bar .table-responsive table { width: 100%; }

.cookies-list-content { width: 100%; display: none; padding-left: 190px; pa=
dding-top: 20px; }

.cookies-list-content > div { padding-right: 20px; min-height: 135px; max-h=
eight: 400px; }

.cookies-list-content p { font-size: 13px; }

div.container-inner div.container-padding { padding: 20px; }

div.container-inner { width: 100%; }

.cookies-bar div.table-responsive { overflow-y: auto; height: 370px; paddin=
g: 0px 20px 0px 0px; width: 100%; }

.cookies-bar div.table-responsive::-webkit-scrollbar { width: 7px; height: =
7px; }

.cookies-bar div.table-responsive::-webkit-scrollbar-track { background: rg=
b(255, 255, 255); }

.cookies-bar div.table-responsive::-webkit-scrollbar-thumb { background: rg=
b(196, 196, 196); }

.cookies-bar div.table-responsive::-webkit-scrollbar-thumb:hover { backgrou=
nd: rgb(85, 85, 85); }

.checkboxAccept { display: inline-block; width: 20px; height: 20px; positio=
n: relative; margin: 0px 12px 0px 0px; background: rgb(184, 184, 184); bord=
er-radius: 3px; }

.checkboxAccept label { width: 18px; height: 18px; position: absolute; top:=
 1px; left: 1px; cursor: pointer; background: radial-gradient(circle, rgb(2=
55, 255, 255), rgb(249, 249, 249), rgb(242, 242, 242), rgb(236, 236, 236), =
rgb(230, 230, 230)) rgb(234, 234, 234); border-width: medium; border-style:=
 none; border-color: currentcolor; border-image: initial; border-radius: 3p=
x; }

.checkboxAccept label::after { content: ""; width: 12px; height: 8px; posit=
ion: absolute; top: 50%; left: 50%; margin-top: -5px; margin-left: -6px; bo=
rder-width: medium medium 4px 4px; border-style: none none solid solid; bor=
der-color: currentcolor currentcolor rgb(0, 159, 223) rgb(0, 159, 223); bor=
der-image: initial; background: transparent; opacity: 0; transform: rotate(=
-45deg); border-radius: 2px; }

.checkboxAccept label.chck-nutne::after { border-color: rgb(196, 196, 196);=
 }

.checkboxAccept label:hover::after { opacity: 0.3; }

.checkboxAccept input[type=3D"checkbox"] { visibility: hidden; }

.checkboxAccept input[type=3D"checkbox"]:checked + label::after { opacity: =
1; }

table.cookies-table { font-size: 12px; margin-bottom: 10px; }

table.cookies-table tr th { font-size: 15px; font-weight: bold; padding: 10=
px 8px; }

table.cookies-table tr td { padding: 15px 8px; border-top: 0px; font-size: =
12px; }

table.cookies-table tr:nth-child(2n+1) td { }

div.cb-overlay { display: none; width: 100%; height: 100%; position: fixed;=
 left: 0px; top: 0px; background: rgb(0, 0, 0); z-index: 99995; }

div#cookies-nutne { display: block; }

div.cookies-list #o-cookies { height: 375px; overflow-y: auto; }

div.cookies-list #o-cookies::-webkit-scrollbar { width: 7px; height: 7px; }

div.cookies-list #o-cookies::-webkit-scrollbar-track { background: rgb(255,=
 255, 255); }

div.cookies-list #o-cookies::-webkit-scrollbar-thumb { background: rgb(196,=
 196, 196); }

div.cookies-list #o-cookies::-webkit-scrollbar-thumb:hover { background: rg=
b(85, 85, 85); }

@media (max-height: 520px) {
  div.cookies-list { position: absolute; top: 20px; margin-top: 0px; transf=
orm: translateX(-50%) translateY(0%); }
}

@media (max-width: 768px) {
  div.cookies-list { position: fixed; top: 20px; left: 20px; transform: non=
e; margin-top: 0px; margin-left: 0px; width: calc(100% - 40px); height: cal=
c(100% - 40px); overflow-y: auto; }
  .cookies-list-content { padding-left: 20px; padding-right: 20px; float: n=
one; }
  .cookies-bar div.table-responsive { width: 100%; padding-right: 0px; heig=
ht: auto; border: 0px; }
  .cookies-bar div.table-responsive::-webkit-scrollbar { width: 0px; height=
: 0px; }
  .cookies-list-menu { float: none; width: 100%; padding-bottom: 20px; }
  .cookies-bar-wrapper .bottom-buttons { flex-direction: column; }
  .cookies-bar-wrapper .bottom-buttons a { margin-bottom: 10px; margin-left=
: 0px !important; }
}

@media (max-width: 580px) {
  .cookies-list-content > div { height: auto; }
  .container-inner.resp-tab-content { width: 100%; max-width: 100%; }
  .cookies-list-content { width: 100%; max-width: 100%; }
  .cookies-bar div.table-responsive { width: 100%; max-width: 100%; overflo=
w-x: scroll; }
}

@media (max-width: 430px) {
  div.bottom-buttons { text-align: center; }
  div.bottom-buttons a { clear: both !important; float: none; }
}

@media (max-width: 390px) {
  .menu.resp-tabs-list { height: auto; max-height: inherit; border: 0px; }
  .menu.resp-tabs-list li { display: block; text-align: center; }
  .menu.resp-tabs-list li.resp-tab-active { border: 0px; }
}
